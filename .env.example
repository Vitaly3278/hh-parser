# Telegram (обязательно)
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here
ALLOWED_CHAT_IDS=123456789,987654321  # Список разрешённых chat_id (опционально)

# Email уведомления (опционально)
EMAIL_ENABLED=false
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_app_password
EMAIL_RECIPIENT=recipient@example.com

# Slack уведомления (опционально)
SLACK_ENABLED=false
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# HH.ru параметры
HH_SEARCH_TEXT=Python разработчик
HH_AREA=
HH_SALARY_FROM=
HH_EMPLOYMENT=
HH_EXPERIENCE=
HH_EXCLUDE_WORDS=стажировка,test

# Интервал проверки (секунды)
CHECK_INTERVAL=300

# База данных
DB_PATH=vacancies.db

# Логирование
LOG_LEVEL=INFO
LOG_FILE=hh_tracker.log
